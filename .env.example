# ==================== SmartTouch 环境变量配置模板 ====================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ---- 数据库 ----
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=你的数据库密码

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码（无密码则留空）

# ---- AI模型API（必填，否则Agent无法工作）----
LLM_API_KEY=你的API密钥
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
VISION_MODEL=qwen-vl-max
